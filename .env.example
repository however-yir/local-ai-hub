########################################
# Open WebUI - Base Configuration
########################################

# Branding
PROJECT_NAME='Open WebUI'
PROJECT_SLUG='open-webui'
WEBUI_NAME='Open WebUI'
PROJECT_DESCRIPTION='A personalized self-hosted AI workspace for private and team usage.'
PROJECT_REPOSITORY_URL='https://github.com/open-webui/open-webui'
PROJECT_LOGO_URL='/static/favicon.svg'
WEBUI_FAVICON_URL='/static/favicon.png'

# Runtime
ENV='dev'
PORT='8080'
HOST='0.0.0.0'

########################################
# Model Provider Endpoints
########################################

# Ollama (single endpoint)
OLLAMA_BASE_URL='http://localhost:11434'

# Ollama (multi endpoint, semicolon separated)
# OLLAMA_BASE_URLS='http://localhost:11434;http://10.0.0.10:11434'

# OpenAI-compatible provider
OPENAI_API_BASE_URL='https://api.openai.com/v1'
OPENAI_API_KEY=''

# OpenAI-compatible provider aliases (optional)
# MODEL_PROVIDER_OPENAI_API_BASE_URL='https://api.openai.com/v1'
# MODEL_PROVIDER_OPENAI_API_KEY=''
# MODEL_PROVIDER_OPENAI_API_BASE_URLS='https://api.openai.com/v1;https://api.deepseek.com/v1'
# MODEL_PROVIDER_OPENAI_API_KEYS='key_for_openai;key_for_deepseek'

########################################
# Database / Redis
########################################

# Preferred: full URL
# DATABASE_URL='postgresql://user:password@127.0.0.1:5432/open_webui'

# Alternative split fields (used when DATABASE_URL is empty)
# DATABASE_TYPE='postgresql'
# DATABASE_USER='postgres'
# DATABASE_PASSWORD='replace_me'
# DATABASE_HOST='127.0.0.1'
# DATABASE_PORT='5432'
# DATABASE_NAME='open_webui'

# SQLite fallback filename (used when no DATABASE_URL and no split DB vars)
DATABASE_FILENAME='webui.db'

# Redis (optional but recommended in production)
REDIS_URL='redis://127.0.0.1:6379/0'
REDIS_KEY_PREFIX='open-webui'

########################################
# Security / CORS
########################################

# Set a strong random secret in production
WEBUI_SECRET_KEY=''

# Local dev can be '*' ; production should use exact origins
CORS_ALLOW_ORIGIN='http://localhost:3000;http://localhost:5173'
FORWARDED_ALLOW_IPS='127.0.0.1'

########################################
# Telemetry / Privacy
########################################

SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false

########################################
# Optional Features
########################################

# AUTOMATIC1111_BASE_URL='http://localhost:7860'
# ENABLE_IMAGE_GENERATION='false'
# ENABLE_WEB_SEARCH='true'
